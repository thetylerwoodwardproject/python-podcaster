# Nginx config for podcast-host
# Replace audio.example.com with your domain throughout.
#
# Setup order:
#   1. Create this file at /etc/nginx/sites-available/audio.example.com
#   2. Symlink feed.xml and media into /var/www/html:
#        ln -s /opt/podcast-host/feed.xml /var/www/html/feed.xml
#        ln -s /opt/podcast-host/media /var/www/html/media
#   3. Enable the site:
#        ln -s /etc/nginx/sites-available/audio.example.com /etc/nginx/sites-enabled/
#        rm /etc/nginx/sites-enabled/default   # remove default site if present
#        nginx -t && systemctl reload nginx
#   4. Test it works:
#        curl http://audio.example.com/feed.xml
#   5. Get your SSL cert:
#        certbot --nginx -d audio.example.com
#      Certbot will update this file automatically with HTTPS config.

server {
    listen 80;
    server_name audio.example.com;
    root /var/www/html;

    location = /feed.xml {
        default_type application/rss+xml;
        add_header Cache-Control "public, max-age=300";
    }

    location /media/ {
        add_header Accept-Ranges bytes;
        add_header Cache-Control "public, max-age=86400";
    }

    location / {
        return 404;
    }
}
